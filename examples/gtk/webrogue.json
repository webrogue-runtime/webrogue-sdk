{
    "name": "GTK example",
    "id": "io.github.webrogue_runtime.GtkExample",
    "version": "0.1.0",
    "main": "build/main",
    "icons": {
        "light": {
            "path": "icon.png",
            "inset": 0.28,
            "background": "#FFFFFF"
        },
        "dark": {
            "path": "icon.png",
            "inset": 0.28,
            "background": "#000000"
        }
    },
    "graphics_api": {
        "vulkan": "disabled",
        "cpu_rendering": "required"
    },
    "env": {
        "FONTCONFIG_FILE": "/usr/share/fonts/fonts.conf"
    },
    "filesystem": {
        "resources": [
            {
                "real_path": "data",
                "mapped_path": "/"
            }
        ],
        "persistent": [
            {
                "mapped_path": "/.cache",
                "name": "cache"
            }
        ]
    }
}